{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/univo/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/univo/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/univo",
  "projects": {
    "univo": {
      "type": "application",
      "root": "apps/univo",
      "entryFile": "main",
      "sourceRoot": "apps/univo/src",
      "compilerOptions": {
        "tsConfigPath": "apps/univo/tsconfig.app.json"
      }
    },
    "univo-batch": {
      "type": "application",
      "root": "apps/univo-batch",
      "entryFile": "main",
      "sourceRoot": "apps/univo-batch/src",
      "compilerOptions": {
        "tsConfigPath": "apps/univo-batch/tsconfig.app.json"
      }
    }
  }
}